<Window x:Class="CodeZipTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="コード検証用 ZIP圧縮ツール" Height="450" Width="550" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="■ 除外するフォルダ・ファイル" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal">
                <CheckBox Name="ChkGit" Content=".git" IsChecked="True" Margin="0,0,15,0"/>
                <CheckBox Name="ChkVs" Content=".vs" IsChecked="True" Margin="0,0,15,0"/>
                <CheckBox Name="ChkBinObj" Content="bin / obj" IsChecked="True" Margin="0,0,15,0"/>
                <CheckBox Name="ChkNodeModules" Content="node_modules" IsChecked="True"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="■ 出力先フォルダ" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Name="TxtOutputDir" Grid.Column="0" IsReadOnly="True" VerticalContentAlignment="Center"/>
                <Button Content="参照..." Grid.Column="1" Width="80" Margin="10,0,0,0" Click="BtnBrowseOutput_Click"/>
            </Grid>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="■ 圧縮対象フォルダ (自動保存されます)" FontWeight="Bold" Margin="0,0,0,5"/>
        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ListBox Name="LstTargetFolders" Grid.Column="0"/>
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Button Content="フォルダ追加" Width="90" Margin="0,0,0,10" Padding="5" Click="BtnAddTarget_Click"/>
                <Button Content="選択を削除" Width="90" Padding="5" Click="BtnRemoveTarget_Click"/>
            </StackPanel>
        </Grid>

        <Button Grid.Row="4" Content="ZIPファイルを作成する" Height="40" FontWeight="Bold" FontSize="14" Background="#FF4CAF50" Foreground="White" Click="BtnRun_Click"/>
    </Grid>
</Window>